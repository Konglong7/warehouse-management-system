@startuml
' --- 通用配置 ---
skinparam shadowing false
skinparam backgroundColor white
skinparam defaultFontName "Microsoft YaHei"
skinparam roundcorner 10

' --- 组件图配置 ---
skinparam component {
    BackgroundColor white
    BorderColor black
    BorderThickness 1.5
    FontSize 16
}

skinparam package {
    BackgroundColor white
    BorderColor black
    BorderThickness 2
    FontSize 18
}

' --- 线条与箭头 ---
skinparam arrow {
    Color black
    Thickness 1.5
}

title 图4-2 系统功能模块图

package "智能仓库管理系统" {

    package "用户管理模块" {
        [用户登录]
        [用户信息管理]
        [密码修改]
        [权限控制]
    }

    package "基础数据管理" {
        package "物料管理" {
            [物料信息维护]
            [物料查询]
            [库存预警]
        }

        package "供应商管理" {
            [供应商信息维护]
            [供应商查询]
        }

        package "仓位管理" {
            [仓位信息维护]
            [仓位状态管理]
        }
    }

    package "业务操作模块" {
        package "入库管理" {
            [入库单录入]
            [入库记录查询]
            [库存自动增加]
        }

        package "出库管理" {
            [出库单录入]
            [出库记录查询]
            [库存校验]
            [库存自动扣减]
        }
    }

    package "查询统计模块" {
        package "库存查询" {
            [库存状态查询]
            [库存预警提示]
        }

        package "数据统计" {
            [关键指标统计]
            [图表可视化]
            [数据分析]
        }
    }

    package "系统支撑模块" {
        [数据库管理]
        [日志管理]
        [操作记录]
    }
}

' --- 模块间关系 ---
[用户登录] ..> [权限控制] : 验证
[权限控制] ..> [用户信息管理] : 授权

[物料信息维护] ..> [数据库管理] : 存储
[供应商信息维护] ..> [数据库管理] : 存储
[仓位信息维护] ..> [数据库管理] : 存储

[入库单录入] ..> [物料查询] : 查询物料
[入库单录入] ..> [仓位状态管理] : 查询仓位
[入库单录入] ..> [库存自动增加] : 触发
[库存自动增加] ..> [数据库管理] : 更新

[出库单录入] ..> [物料查询] : 查询物料
[出库单录入] ..> [库存校验] : 校验
[库存校验] ..> [库存自动扣减] : 通过后触发
[库存自动扣减] ..> [数据库管理] : 更新

[库存状态查询] ..> [数据库管理] : 查询
[库存状态查询] ..> [库存预警提示] : 判断预警
[库存预警提示] ..> [库存预警] : 关联

[关键指标统计] ..> [数据库管理] : 统计
[图表可视化] ..> [关键指标统计] : 展示

[操作记录] ..> [日志管理] : 记录
[用户信息管理] ..> [操作记录] : 记录操作
[入库单录入] ..> [操作记录] : 记录操作
[出库单录入] ..> [操作记录] : 记录操作

@enduml
